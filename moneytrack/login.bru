meta {
  name: login
  type: http
  seq: 1
}

post {
  url: {{url}}/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}"
  }
}

script:post-response {
  if (res.getBody() && res.getBody().token) {
      bru.setVar("token", res.getBody().token);
  }
}
